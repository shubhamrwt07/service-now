# Server PORT (backend container ke andar)
PORT=5000

# PostgreSQL Database Connection
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@postgres:5432/servicenow_db

# ServiceNow OAuth Settings
OAUTH_CLIENT_ID=your_oauth_client_id_here
OAUTH_CLIENT_SECRET=your_oauth_client_secret_here
OAUTH_REDIRECT_URI=http://your-domain.com

# Environment
NODE_ENV=production
